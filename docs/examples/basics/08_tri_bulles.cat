# Tri à bulles

trier_bulles = (liste) => {
    n = len(liste)
    i = 0
    while i < n - 1 {
        j = 0
        while j < n - i - 1 {
            if liste[j] > liste[j + 1] {
                temp = liste[j]
                liste[j] = liste[j + 1]
                liste[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    liste
}

nombres = list(64, 34, 25, 12, 22, 11, 90)
trie = trier_bulles(nombres)
print("Liste triée:", trie)
