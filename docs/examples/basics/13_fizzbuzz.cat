#!/usr/bin/env catnip
# FizzBuzz

fizzbuzz = (n) => {
    for i in range(1, n + 1) {
        match i {
            i if i % 15 == 0 => { print("FizzBuzz") }
            i if i % 3 == 0  => { print("Fizz") }
            i if i % 5 == 0  => { print("Buzz") }
            i                => { print(i) }
        }
    }
}

fizzbuzz(20)
