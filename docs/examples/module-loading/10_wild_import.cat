#!/usr/bin/env catnip
# RUN: cd docs/examples/module-loading && catnip 10_wild_import.cat
# Import global : injecter directement les exports dans les globals

# Import classique : les fonctions vivent sous un namespace
host = import('host_module_example', protocol='py')
host.add(1, 2)

# Import global : les fonctions sont injectées dans les globals
import('host_module_example', protocol='py', wild=True)
add(10, 20)
multiply(3, 7)
